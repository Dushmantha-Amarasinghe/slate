<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp"
    android:id="@+id/widget_root">

    <!-- Header: "Today" + quick-add button, tapping either opens the app. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Today"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />

        <TextView
            android:id="@+id/widget_add_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_add_button_background"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/widget_add_button_fg"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />
    </LinearLayout>

    <!-- RemoteViews only allows a fixed whitelist of View classes — plain
         <View> isn't in it ("Class not allowed to be inflated") — so the
         divider is a zero-text FrameLayout with a solid background instead. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@color/widget_divider" />

    <TextView
        android:id="@+id/widget_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="No tasks today"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />
</LinearLayout>
