# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Release signing (spec section 8) — the keystore and its credentials must
# never be committed. Store 2 secure backups outside this repo; CI gets the
# keystore from an encrypted GitHub Actions secret instead of this file.
/android/key.properties
*.jks
*.keystore

# Claude Code local tool settings — not part of the app.
.claude/

# Android-only app (see todo-app-spec.md) — the Windows desktop scaffold
# was generated by `flutter create` but was never developed against.
/windows/
